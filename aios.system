<?xml version="1.0" encoding="UTF-8"?>
<system>
    <!-- ── Memory regions ── -->
    <memory_region name="uart_mmio" size="0x1000" phys_addr="0x9000000" />
    <memory_region name="rx_buf"    size="0x1000" />
    <memory_region name="tx_buf"    size="0x1000" />
    <memory_region name="blk_mmio"  size="0x1000" phys_addr="0x0a003000" />
    <memory_region name="blk_dma"   size="0x10000" phys_addr="0xB0000000" />
    <memory_region name="blk_data"  size="0x10000" />
    <memory_region name="fs_data"   size="0x10000" />

    <!-- 128 MiB region for model weights -->
    <memory_region name="model_data" size="0x8000000" />

    <!-- 4 KiB IPC buffer: orchestrator <-> llm_server -->
    <memory_region name="llm_io" size="0x4000" />

    <!-- ── Sandbox memory regions (4 slots) ── -->
    <!-- Each sandbox: 4 KiB IO + 4 MiB heap + 1 MiB code = ~5 MiB -->
    <memory_region name="sbx0_io"   size="0x1000" />
    <memory_region name="sbx0_heap" size="0x400000" />
    <memory_region name="sbx0_code" size="0x100000" />

    <memory_region name="sbx1_io"   size="0x1000" />
    <memory_region name="sbx1_heap" size="0x400000" />
    <memory_region name="sbx1_code" size="0x100000" />

    <memory_region name="sbx2_io"   size="0x1000" />
    <memory_region name="sbx2_heap" size="0x400000" />
    <memory_region name="sbx2_code" size="0x100000" />

    <memory_region name="sbx3_io"   size="0x1000" />
    <memory_region name="sbx3_heap" size="0x400000" />
    <memory_region name="sbx3_code" size="0x100000" />

    <memory_region name="sbx4_io"   size="0x1000" />
    <memory_region name="sbx4_heap" size="0x400000" />
    <memory_region name="sbx4_code" size="0x100000" />

    <memory_region name="sbx5_io"   size="0x1000" />
    <memory_region name="sbx5_heap" size="0x400000" />
    <memory_region name="sbx5_code" size="0x100000" />

    <memory_region name="sbx6_io"   size="0x1000" />
    <memory_region name="sbx6_heap" size="0x400000" />
    <memory_region name="sbx6_code" size="0x100000" />

    <memory_region name="sbx7_io"   size="0x1000" />
    <memory_region name="sbx7_heap" size="0x400000" />
    <memory_region name="sbx7_code" size="0x100000" />


    <!-- ── Serial driver (priority 254) ── -->
    <memory_region name="auth_io" size="0x1000" />
    <memory_region name="auth_store" size="0x10000" />

    <protection_domain name="serial_driver" priority="254">
        <program_image path="serial_driver.elf" />
        <map mr="uart_mmio" vaddr="0x4000000" perms="rw" cached="false"
             setvar_vaddr="uart_base_vaddr" />
        <map mr="rx_buf"    vaddr="0x4200000" perms="rw" cached="false"
             setvar_vaddr="rx_buf" />
        <map mr="tx_buf"    vaddr="0x4201000" perms="rw" cached="false"
             setvar_vaddr="tx_buf" />
        <irq irq="33" id="2" />
    </protection_domain>

    <!-- ── Block driver (priority 250) ── -->
    <protection_domain name="blk_driver" priority="250">
        <program_image path="blk_driver.elf" />
        <map mr="blk_mmio" vaddr="0x5000000" perms="rw" cached="false"
             setvar_vaddr="virtio_blk_base_vaddr" />
        <map mr="blk_dma"  vaddr="0x5100000" perms="rw" cached="false"
             setvar_vaddr="dma_base" />
        <map mr="blk_data" vaddr="0x5200000" perms="rw" cached="false"
             setvar_vaddr="blk_data" />
    </protection_domain>

    <!-- ── Filesystem server (priority 240) ── -->
    <protection_domain name="fs_server" priority="240">
        <program_image path="fs_server.elf" />
        <map mr="blk_data" vaddr="0x6000000" perms="rw" cached="false"
             setvar_vaddr="blk_data" />
        <map mr="fs_data"  vaddr="0x6100000" perms="rw" cached="false"
             setvar_vaddr="fs_data" />
    </protection_domain>

    <!-- ── Orchestrator (priority 200) with child sandbox PDs ── -->
    <protection_domain name="orchestrator" priority="200">
        <program_image path="orchestrator.elf" />
        <map mr="rx_buf"      vaddr="0x4200000" perms="rw" cached="false"
             setvar_vaddr="rx_buf" />
        <map mr="tx_buf"      vaddr="0x4201000" perms="rw" cached="false"
             setvar_vaddr="tx_buf" />
        <map mr="fs_data"     vaddr="0x6100000" perms="rw" cached="false"
             setvar_vaddr="fs_data" />
        <map mr="model_data"  vaddr="0x10000000" perms="rw" cached="true"
             setvar_vaddr="model_data" />
        <map mr="llm_io"      vaddr="0x18100000" perms="rw" cached="false"
             setvar_vaddr="llm_io" />

        <!-- Orchestrator maps all sandbox memory for code loading -->
        <map mr="sbx0_io"   vaddr="0x20000000" perms="rw" cached="false"
             setvar_vaddr="sbx0_io" />
        <map mr="sbx0_code" vaddr="0x20500000" perms="rw" cached="false"
             setvar_vaddr="sbx0_code" />
        <map mr="sbx1_io"   vaddr="0x21000000" perms="rw" cached="false"
             setvar_vaddr="sbx1_io" />
        <map mr="sbx1_code" vaddr="0x21500000" perms="rw" cached="false"
             setvar_vaddr="sbx1_code" />
        <map mr="sbx2_io"   vaddr="0x22000000" perms="rw" cached="false"
             setvar_vaddr="sbx2_io" />
        <map mr="sbx2_code" vaddr="0x22500000" perms="rw" cached="false"
             setvar_vaddr="sbx2_code" />
        <map mr="sbx3_io"   vaddr="0x23000000" perms="rw" cached="false"
             setvar_vaddr="sbx3_io" />
        <map mr="sbx3_code" vaddr="0x23500000" perms="rw" cached="false"
             setvar_vaddr="sbx3_code" />
            <map mr="sbx4_io"   vaddr="0x24000000" perms="rw" cached="false"
                 setvar_vaddr="sbx4_io" />
            <map mr="sbx4_code" vaddr="0x24500000" perms="rw" cached="false"
                 setvar_vaddr="sbx4_code" />
            <map mr="sbx5_io"   vaddr="0x25000000" perms="rw" cached="false"
                 setvar_vaddr="sbx5_io" />
            <map mr="sbx5_code" vaddr="0x25500000" perms="rw" cached="false"
                 setvar_vaddr="sbx5_code" />
            <map mr="sbx6_io"   vaddr="0x26000000" perms="rw" cached="false"
                 setvar_vaddr="sbx6_io" />
            <map mr="sbx6_code" vaddr="0x26500000" perms="rw" cached="false"
                 setvar_vaddr="sbx6_code" />
            <map mr="sbx7_io"   vaddr="0x27000000" perms="rw" cached="false"
                 setvar_vaddr="sbx7_io" />
            <map mr="sbx7_code" vaddr="0x27500000" perms="rw" cached="false"
                 setvar_vaddr="sbx7_code" />

        <!-- ── Child sandbox PD 0 ── -->
        <map mr="auth_io" vaddr="0x6200000" perms="rw" cached="false"
             setvar_vaddr="auth_io" />

        <protection_domain name="sbx0" priority="150" id="0"
                           budget="5000" period="10000" cpu="1">
            <program_image path="sandbox.elf" />
            <map mr="sbx0_io"   vaddr="0x20000000" perms="rw" cached="false"
                 setvar_vaddr="sandbox_io" />
            <map mr="sbx0_heap" vaddr="0x20100000" perms="rw" cached="true"
                 setvar_vaddr="sandbox_heap" />
            <map mr="sbx0_code" vaddr="0x20500000" perms="rwx" cached="false"
                 setvar_vaddr="sandbox_code" />
        </protection_domain>

        <!-- ── Child sandbox PD 1 ── -->
        <protection_domain name="sbx1" priority="150" id="1"
                           budget="5000" period="10000" cpu="1">
            <program_image path="sandbox.elf" />
            <map mr="sbx1_io"   vaddr="0x20000000" perms="rw" cached="false"
                 setvar_vaddr="sandbox_io" />
            <map mr="sbx1_heap" vaddr="0x20100000" perms="rw" cached="true"
                 setvar_vaddr="sandbox_heap" />
            <map mr="sbx1_code" vaddr="0x20500000" perms="rwx" cached="false"
                 setvar_vaddr="sandbox_code" />
        </protection_domain>

        <!-- ── Child sandbox PD 2 ── -->
        <protection_domain name="sbx2" priority="150" id="2"
                           budget="5000" period="10000" cpu="2">
            <program_image path="sandbox.elf" />
            <map mr="sbx2_io"   vaddr="0x20000000" perms="rw" cached="false"
                 setvar_vaddr="sandbox_io" />
            <map mr="sbx2_heap" vaddr="0x20100000" perms="rw" cached="true"
                 setvar_vaddr="sandbox_heap" />
            <map mr="sbx2_code" vaddr="0x20500000" perms="rwx" cached="false"
                 setvar_vaddr="sandbox_code" />
        </protection_domain>

        <!-- ── Child sandbox PD 3 ── -->
        <protection_domain name="sbx3" priority="150" id="3"
                           budget="5000" period="10000" cpu="3">
            <program_image path="sandbox.elf" />
            <map mr="sbx3_io"   vaddr="0x20000000" perms="rw" cached="false"
                 setvar_vaddr="sandbox_io" />
            <map mr="sbx3_heap" vaddr="0x20100000" perms="rw" cached="true"
                 setvar_vaddr="sandbox_heap" />
            <map mr="sbx3_code" vaddr="0x20500000" perms="rwx" cached="false"
                 setvar_vaddr="sandbox_code" />
        </protection_domain>

        <protection_domain name="sbx4" priority="150" id="4"
                           budget="5000" period="10000" cpu="0">
            <program_image path="sandbox.elf" />
            <map mr="sbx4_io"   vaddr="0x20000000" perms="rw" cached="false"
                 setvar_vaddr="sandbox_io" />
            <map mr="sbx4_heap" vaddr="0x20100000" perms="rw" cached="true"
                 setvar_vaddr="sandbox_heap" />
            <map mr="sbx4_code" vaddr="0x20500000" perms="rwx" cached="false"
                 setvar_vaddr="sandbox_code" />
        </protection_domain>

        <protection_domain name="sbx5" priority="150" id="5"
                           budget="5000" period="10000" cpu="1">
            <program_image path="sandbox.elf" />
            <map mr="sbx5_io"   vaddr="0x20000000" perms="rw" cached="false"
                 setvar_vaddr="sandbox_io" />
            <map mr="sbx5_heap" vaddr="0x20100000" perms="rw" cached="true"
                 setvar_vaddr="sandbox_heap" />
            <map mr="sbx5_code" vaddr="0x20500000" perms="rwx" cached="false"
                 setvar_vaddr="sandbox_code" />
        </protection_domain>

        <protection_domain name="sbx6" priority="150" id="6"
                           budget="5000" period="10000" cpu="2">
            <program_image path="sandbox.elf" />
            <map mr="sbx6_io"   vaddr="0x20000000" perms="rw" cached="false"
                 setvar_vaddr="sandbox_io" />
            <map mr="sbx6_heap" vaddr="0x20100000" perms="rw" cached="true"
                 setvar_vaddr="sandbox_heap" />
            <map mr="sbx6_code" vaddr="0x20500000" perms="rwx" cached="false"
                 setvar_vaddr="sandbox_code" />
        </protection_domain>

        <protection_domain name="sbx7" priority="150" id="7"
                           budget="5000" period="10000" cpu="3">
            <program_image path="sandbox.elf" />
            <map mr="sbx7_io"   vaddr="0x20000000" perms="rw" cached="false"
                 setvar_vaddr="sandbox_io" />
            <map mr="sbx7_heap" vaddr="0x20100000" perms="rw" cached="true"
                 setvar_vaddr="sandbox_heap" />
            <map mr="sbx7_code" vaddr="0x20500000" perms="rwx" cached="false"
                 setvar_vaddr="sandbox_code" />
        </protection_domain>
    </protection_domain>

    <!-- ── LLM server (priority 180) ── -->
    <protection_domain name="llm_server" priority="180" stack_size="0x10000">
        <program_image path="llm_server.elf" />
        <map mr="model_data" vaddr="0x10000000" perms="rw" cached="true" setvar_vaddr="model_data" />
        <map mr="llm_io"      vaddr="0x18100000" perms="rw" cached="false"
             setvar_vaddr="llm_io" />
    </protection_domain>

    <!-- ── Echo server (priority 100) ── -->
    <protection_domain name="echo_server" priority="100">
        <program_image path="echo_server.elf" />
    </protection_domain>

    <!-- ── Channels ── -->
    <!-- serial_driver <-> orchestrator -->
    <channel>
        <end pd="serial_driver" id="1" />
        <end pd="orchestrator"  id="1" />
    </channel>

    <!-- orchestrator <-> blk_driver -->
    <channel>
        <end pd="orchestrator"  id="2" />
        <end pd="blk_driver"    id="2" />
    </channel>

    <!-- orchestrator <-> echo_server -->
    <channel>
        <end pd="orchestrator"  id="3" />
        <end pd="echo_server"   id="3" />
    </channel>

    <!-- orchestrator <-> fs_server -->
    <channel>
        <end pd="orchestrator"  id="4" pp="true" />
        <end pd="fs_server"     id="4" />
    </channel>

    <!-- orchestrator <-> llm_server -->
    <channel>
        <end pd="orchestrator"  id="6" />
        <end pd="llm_server"    id="6" />
    </channel>

    <!-- orchestrator <-> sandbox children (PPC channels) -->
    <channel>
        <end pd="orchestrator"  id="7" />
        <end pd="sbx0"          id="7" pp="true" />
    </channel>
    <channel>
        <end pd="orchestrator"  id="8" />
        <end pd="sbx1"          id="8" pp="true" />
    </channel>
    <channel>
        <end pd="orchestrator"  id="9" />
        <end pd="sbx2"          id="9" pp="true" />
    </channel>
    <channel>
        <end pd="orchestrator"  id="10" />
        <end pd="sbx3"          id="10" pp="true" />
    </channel>
    <channel>
        <end pd="orchestrator"  id="14" />
        <end pd="sbx4"          id="14" pp="true" />
    </channel>
    <channel>
        <end pd="orchestrator"  id="15" />
        <end pd="sbx5"          id="15" pp="true" />
    </channel>
    <channel>
        <end pd="orchestrator"  id="16" />
        <end pd="sbx6"          id="16" pp="true" />
    </channel>
    <channel>
        <end pd="orchestrator"  id="17" />
        <end pd="sbx7"          id="17" pp="true" />
    </channel>

    <!-- ── Memory regions for network ── -->
    <memory_region name="net_dma"   size="0x20000" phys_addr="0xB0100000" />
    <memory_region name="net_data"  size="0x10000" />

    <!-- ── Network driver (priority 230) ── -->

    <!-- ── Auth server (priority 210) ── -->
    <protection_domain name="auth_server" priority="210">
        <program_image path="auth_server.elf" />
        <map mr="auth_io" vaddr="0x30000000" perms="rw" cached="false"
             setvar_vaddr="auth_io" />
        <map mr="auth_store" vaddr="0x30100000" perms="rw" cached="true"
             setvar_vaddr="auth_store" />
    </protection_domain>

    <protection_domain name="net_driver" priority="230">
        <program_image path="net_driver.elf" />
        <map mr="blk_mmio" vaddr="0x5200000" perms="rw" cached="false"
             setvar_vaddr="virtio_net_base_vaddr" />
        <map mr="net_dma"  vaddr="0x5300000" perms="rw" cached="false"
             setvar_vaddr="net_dma_base" />
        <map mr="net_data" vaddr="0x5500000" perms="rw" cached="false"
             setvar_vaddr="net_data" />
        <irq irq="78" id="9" />
    </protection_domain>


    <!-- orchestrator <-> auth_server (PPC) -->
    <channel>
        <end pd="orchestrator"  id="11" pp="true" />
        <end pd="auth_server"   id="1" />
    </channel>

    <!-- net_driver <-> net_server -->
    <channel>
        <end pd="net_driver"    id="8" />
        <end pd="net_server"    id="8" />
    </channel>

    <!-- ── Network server / IP stack (priority 210) ── -->
    <protection_domain name="net_server" priority="210">
        <program_image path="net_server.elf" />
        <map mr="net_data" vaddr="0x5500000" perms="rw" cached="false"
             setvar_vaddr="net_data" />
    </protection_domain>

    <!-- fs_server <-> blk_driver -->
    <channel>
        <end pd="fs_server"     id="10" />
        <end pd="blk_driver"    id="10" />
    </channel>
</system>
